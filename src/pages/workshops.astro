---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
---

<BaseLayout title="Workshops" description="Launch Day workshop stations — compare notes across schools through structured discussion and collaborative feedback.">
  <PageHero
    title="Launch Day Workshops"
    subtitle="Three rotating stations, 20 minutes each. Share your school's experience, compare approaches, and capture your thinking on the Padlet."
    badge="31 March 2026"
  />

  <!-- Workshop cards -->
  <section class="section">
    <div class="container">
      <div class="workshop-stack">

        <!-- Station A: Teaching & Learning -->
        <a href="#station-a" class="workshop-card workshop-card--tl">
          <div class="workshop-card__badge">Station A</div>
          <div class="workshop-card__content">
            <span class="workshop-card__section">Teaching &amp; Learning</span>
            <h2>How Is Your School Approaching AI in the Classroom?</h2>
            <p>Compare notes on how your schools are navigating AI use in teaching, learning, and assessment.</p>
          </div>
          <div class="workshop-card__arrow">&darr;</div>
        </a>

        <!-- Station B: Ethics & Wellbeing -->
        <a href="#station-b" class="workshop-card workshop-card--ew">
          <div class="workshop-card__badge">Station B</div>
          <div class="workshop-card__content">
            <span class="workshop-card__section">Ethics &amp; Wellbeing</span>
            <h2>What Are the Emerging Ethical Challenges?</h2>
            <p>Share experiences and approaches to the ethical and wellbeing dimensions of AI in your school community.</p>
          </div>
          <div class="workshop-card__arrow">&darr;</div>
        </a>

        <!-- Station C: Privacy & Security -->
        <a href="#station-c" class="workshop-card workshop-card--ps">
          <div class="workshop-card__badge">Station C</div>
          <div class="workshop-card__content">
            <span class="workshop-card__section">Privacy &amp; Security</span>
            <h2>What Does Your School&rsquo;s AI Privacy Landscape Look Like?</h2>
            <p>Discuss current policies, data concerns, and practical approaches to managing AI privacy and security.</p>
          </div>
          <div class="workshop-card__arrow">&darr;</div>
        </a>

      </div>
    </div>
  </section>

  <!-- Station A Detail -->
  <section class="section section--gray" id="station-a">
    <div class="container content-narrow">
      <span class="badge" style="background: color-mix(in srgb, var(--color-tl) 15%, white); color: var(--color-tl);">Station A &middot; Teaching &amp; Learning</span>
      <h2>How Is Your School Approaching AI in the Classroom?</h2>

      <div class="workshop-preamble">
        <p>Use this station to compare notes with colleagues from other schools. Discuss the prompts below for <strong>10–15 minutes</strong>, then open the Padlet (QR code on your table) and add your table's key takeaways, questions, and feedback on the <strong>Teaching &amp; Learning</strong> section of the guidelines.</p>
      </div>

      <div class="workshop-prompt">
        <h3>Completion Prompts</h3>
        <p>Complete these sentences from your school's perspective, then compare with your table:</p>
        <ul>
          <li><strong>Right now, AI in our classrooms looks like&hellip;</strong> (who's using it, how, and what policies or expectations are in place)</li>
          <li><strong>The approach that's worked best for us is&hellip;</strong> and <strong>the thing we still can't get right is&hellip;</strong></li>
        </ul>
      </div>

      <div class="callout callout--highlight">
        <p><strong>Padlet prompt:</strong> What is the most useful idea or approach you heard from another school at this station? What question are you still wrestling with? <a href="https://padlet.com/mheinrich13/ai-in-victorian-schools-attendee-sharing-qfbsan3sq8ggiwb0" target="_blank" rel="noopener">Open Padlet &rarr;</a></p>
      </div>
    </div>
  </section>

  <!-- Station B Detail -->
  <section class="section" id="station-b">
    <div class="container content-narrow">
      <span class="badge" style="background: color-mix(in srgb, var(--color-ew) 12%, white); color: var(--color-ew);">Station B &middot; Ethics &amp; Wellbeing</span>
      <h2>What Are the Emerging Ethical Challenges?</h2>

      <div class="workshop-preamble">
        <p>Use this station to compare notes with colleagues from other schools. Discuss the prompts below for <strong>10–15 minutes</strong>, then open the Padlet (QR code on your table) and add your table's key takeaways, questions, and feedback on the <strong>Ethics &amp; Wellbeing</strong> section of the guidelines.</p>
      </div>

      <div class="workshop-prompt">
        <h3>Completion Prompts</h3>
        <p>Complete these sentences from your school's perspective, then compare with your table:</p>
        <ul>
          <li><strong>The AI ethics or wellbeing issue that's hit us hardest is&hellip;</strong> (deepfakes, academic integrity, student dependency, or something else — and how you responded)</li>
          <li><strong>We feel most prepared for&hellip;</strong> and <strong>least prepared for&hellip;</strong></li>
        </ul>
      </div>

      <div class="callout callout--highlight">
        <p><strong>Padlet prompt:</strong> What is the most useful idea or approach you heard from another school at this station? What question are you still wrestling with? <a href="https://padlet.com/mheinrich13/ai-in-victorian-schools-attendee-sharing-qfbsan3sq8ggiwb0" target="_blank" rel="noopener">Open Padlet &rarr;</a></p>
      </div>
    </div>
  </section>

  <!-- Station C Detail -->
  <section class="section section--gray" id="station-c">
    <div class="container content-narrow">
      <span class="badge" style="background: color-mix(in srgb, var(--color-ps) 15%, white); color: var(--color-ps);">Station C &middot; Privacy &amp; Security</span>
      <h2>What Does Your School&rsquo;s AI Privacy Landscape Look Like?</h2>

      <div class="workshop-preamble">
        <p>Use this station to compare notes with colleagues from other schools. Discuss the prompts below for <strong>10–15 minutes</strong>, then open the Padlet (QR code on your table) and add your table's key takeaways, questions, and feedback on the <strong>Privacy &amp; Security</strong> section of the guidelines.</p>
      </div>

      <div class="workshop-prompt">
        <h3>Completion Prompts</h3>
        <p>Complete these sentences from your school's perspective, then compare with your table:</p>
        <ul>
          <li><strong>Our biggest AI privacy and safety challenge is&hellip;</strong> (approved tools lists, vetting processes, student data guidelines, or something else)</li>
          <li><strong>The hardest part of managing AI privacy in practice is&hellip;</strong> (shadow AI, vendor claims, staff awareness, or something else)</li>
        </ul>
      </div>

      <div class="callout callout--highlight">
        <p><strong>Padlet prompt:</strong> What is the most useful idea or approach you heard from another school at this station? What question are you still wrestling with? <a href="https://padlet.com/mheinrich13/ai-in-victorian-schools-attendee-sharing-qfbsan3sq8ggiwb0" target="_blank" rel="noopener">Open Padlet &rarr;</a></p>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="section">
    <div class="container content-narrow" style="text-align: center;">
      <h2>How the Jigsaw Works</h2>
      <p class="lead" style="margin-bottom: 2rem;">Three stations, three rotations. Every table visits every station.</p>
      <div class="jigsaw-steps">
        <div class="jigsaw-step">
          <div class="jigsaw-step__number">1</div>
          <p><strong>Discuss</strong><br />Spend 10–15 minutes sharing your school's experiences and comparing approaches with your table.</p>
        </div>
        <div class="jigsaw-step">
          <div class="jigsaw-step__number">2</div>
          <p><strong>Share on Padlet</strong><br />Use the QR code on your table to add your table's key takeaways and questions.</p>
        </div>
        <div class="jigsaw-step">
          <div class="jigsaw-step__number">3</div>
          <p><strong>Rotate</strong><br />Move to the next station. Build on what previous groups have posted.</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Workshop card stack */
  .workshop-stack {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    max-width: 900px;
    margin: 0 auto;
  }

  .workshop-card {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    background: var(--color-white);
    border: 1px solid var(--color-gray-200);
    border-radius: 12px;
    padding: 2rem 2.5rem;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    text-decoration: none;
    color: inherit;
    position: relative;
    overflow: hidden;
  }

  .workshop-card::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 5px;
  }

  .workshop-card--tl::before { background: var(--color-tl); }
  .workshop-card--ew::before { background: var(--color-ew); }
  .workshop-card--ps::before { background: var(--color-ps); }

  .workshop-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.08);
  }

  .workshop-card__badge {
    flex-shrink: 0;
    width: 80px;
    height: 80px;
    border-radius: 12px;
    background: var(--color-gray-50);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 0.875rem;
    color: var(--color-gray-500);
    text-align: center;
    line-height: 1.3;
  }

  .workshop-card--tl .workshop-card__badge { background: color-mix(in srgb, var(--color-tl) 12%, white); color: var(--color-tl); }
  .workshop-card--ew .workshop-card__badge { background: color-mix(in srgb, var(--color-ew) 10%, white); color: var(--color-ew); }
  .workshop-card--ps .workshop-card__badge { background: color-mix(in srgb, var(--color-ps) 12%, white); color: var(--color-ps); }

  .workshop-card__content {
    flex: 1;
  }

  .workshop-card__section {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-gray-500);
    display: block;
    margin-bottom: 0.25rem;
  }

  .workshop-card__content h2 {
    font-size: 1.375rem;
    margin-bottom: 0.375rem;
  }

  .workshop-card__content p {
    color: var(--color-gray-700);
    font-size: 0.9375rem;
    margin: 0;
    line-height: 1.6;
  }

  .workshop-card__arrow {
    flex-shrink: 0;
    font-size: 1.25rem;
    color: var(--color-gray-300);
    transition: color 0.2s ease;
  }

  .workshop-card:hover .workshop-card__arrow {
    color: var(--color-highlight);
  }

  /* Workshop preamble */
  .workshop-preamble {
    background: var(--color-highlight-light);
    border-radius: 12px;
    padding: 1.5rem 2rem;
    margin: 1.5rem 0 2rem;
  }

  .workshop-preamble p {
    margin: 0;
    line-height: 1.8;
  }

  /* Discussion prompt */
  .workshop-prompt {
    margin-bottom: 2rem;
    padding: 2rem;
    border: 2px solid var(--color-gray-200);
    border-radius: 12px;
    background: var(--color-white);
  }

  .workshop-prompt h3 {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-highlight-dark);
    margin-bottom: 1rem;
  }

  .workshop-prompt ul {
    margin: 0.5rem 0 0 1.5rem;
    line-height: 1.8;
  }

  .workshop-prompt li {
    margin-bottom: 0.5rem;
  }

  .callout {
    padding: 1.25rem 1.5rem;
    border-radius: 8px;
    margin-top: 1.5rem;
  }
  .callout--highlight {
    background: var(--color-highlight-light);
    border-left: 4px solid var(--color-highlight);
  }
  .callout p { margin: 0; }

  /* Jigsaw steps */
  .jigsaw-steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    text-align: center;
  }

  .jigsaw-step__number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--color-navy);
    color: var(--color-white);
    font-weight: 700;
    font-size: 1.25rem;
    margin-bottom: 1rem;
  }

  .jigsaw-step p {
    font-size: 0.9375rem;
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .workshop-card {
      flex-direction: column;
      padding: 1.5rem;
      text-align: center;
    }

    .workshop-card__arrow { display: none; }

    .workshop-preamble {
      padding: 1.25rem 1.5rem;
    }

    .workshop-prompt {
      padding: 1.5rem;
    }

    .jigsaw-steps {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }
</style>
